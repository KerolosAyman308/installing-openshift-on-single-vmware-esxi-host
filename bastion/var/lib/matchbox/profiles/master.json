{
    "id": "master",
    "name": "OCP 4 – Master",
    "ignition_id": "master.ign",
    "boot": {
        "kernel": "/assets/rhcos-4.2.18-x86_64-installer-kernel",
        "initrd": [
            "/assets/rhcos-4.2.18-x86_64-installer-initramfs.img"
        ],
        "args": [
            "ip=dhcp",
            "rd.neednet=1",
            "console=tty0",
            "console=ttyS0",
            "coreos.inst=yes",
            "coreos.inst.install_dev=sda",
            "coreos.inst.image_url=http://bastion.ocp.koko:8080/assets/rhcos-4.2.18-x86_64-metal-bios.raw.gz",
            "coreos.inst.ignition_url=http://bastion.ocp.koko:8080/ignition?mac=${mac:hexhyp}",
            "rd.iscsi.disable=1",
            "systemd.mask=iscsid.service",
            "systemd.mask=iscsiuio.service",
            "systemd.mask=open-iscsi.service",
            "modprobe.blacklist=uas,usb_storage,iscsi_tcp,libiscsi,libiscsi_tcp,scsi_transport_iscsi"
        ]
    }
}