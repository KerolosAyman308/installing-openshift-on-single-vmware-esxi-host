$TTL 900
@       IN      SOA     bastion.ocp.koko.       hostmaster.ocp.koko. (
                2019062002 ; serial
                1D ; refresh after one day
                1H ; retry after one hour
                1W ; expire after 1 week
                3H ; minimum TTL of 1 day
)

        IN      NS      bastion.ocp.koko.
bastion         IN      A       192.168.171.40
bootstrap       IN      A       192.168.171.50
master-0        IN      A       192.168.171.41
master-1        IN      A       192.168.171.42
master-2        IN      A       192.168.171.43
;infnod-0 IN A 192.168.171.44
;infnod-1 IN A 192.168.171.45
cptnod-0        IN      A       192.168.171.46
cptnod-1        IN      A       192.168.171.47
;cptnod-2 IN A 192.168.171.48
api             IN      A       192.168.171.40
api-int         IN      A       192.168.171.40
apps            IN      A       192.168.171.40
*.apps          IN      A       192.168.171.40
etcd-0          IN      A       192.168.171.41
etcd-1          IN      A       192.168.171.42
etcd-2          IN      A       192.168.171.43
_etcd-server-ssl._tcp   IN      SRV     0       10      2380    etcd-0.ocp.koko.
                        IN      SRV     0       10      2380    etcd-1.ocp.koko.
                        IN      SRV     0       10      2380    etcd-2.ocp.koko.